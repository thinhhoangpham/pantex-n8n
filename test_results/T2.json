AMP AS load_dts,\n  NULL AS load_end_dts,\n  'erp.locations' AS record_source,\n  md5(\n    UPPER(TRIM(COALESCE(CAST(s.location_name AS VARCHAR), '')))\n    || '|' || UPPER(TRIM(COALESCE(CAST(s.cost_rate AS VARCHAR), '')))\n    || '|' || UPPER(TRIM(COALESCE(CAST(s.capacity AS VARCHAR), '')))\n  ) AS hashdiff,\n  s.location_name,\n  s.cost_rate,\n  s.capacity\nFROM stg_erp_locations s\nWHERE NOT EXISTS (\n  SELECT 1 FROM sat_location_details sat\n  WHERE sat.location_hk = md5(UPPER(TRIM(CAST(s.location_id AS VARCHAR))))\n  AND sat.hashdiff = md5(\n    UPPER(TRIM(COALESCE(CAST(s.location_name AS VARCHAR), '')))\n    || '|' || UPPER(TRIM(COALESCE(CAST(s.cost_rate AS VARCHAR), '')))\n    || '|' || UPPER(TRIM(COALESCE(CAST(s.capacity AS VARCHAR), '')))\n  )\n  AND sat.load_end_dts IS NULL\n)"},{"table_name":"sat_warehouse_capacity","table_type":"SATELLITE","ddl":"CREATE TABLE IF NOT EXISTS sat_warehouse_capacity (\n  warehouse_hk VARCHAR(32) NOT NULL,\n  load_dts TIMESTAMP NOT NULL,\n  load_end_dts TIMESTAMP,\n  record_source VARCHAR NOT NULL,\n  hashdiff VARCHAR(32) NOT NULL,\n  warehouse_name VARCHAR,\n  city VARCHAR,\n  capacity_sqft BIGINT\n)","load_sql":"INSERT INTO sat_warehouse_capacity\nSELECT DISTINCT\n  md5(UPPER(TRIM(CAST(s.warehouse_id AS VARCHAR)))) AS warehouse_hk,\n  CURRENT_TIMESTAMP AS load_dts,\n  NULL AS load_end_dts,\n  'wms.warehouses' AS record_source,\n  md5(\n    UPPER(TRIM(COALESCE(CAST(s.warehouse_name AS VARCHAR), '')))\n    || '|' || UPPER(TRIM(COALESCE(CAST(s.city AS VARCHAR), '')))\n    || '|' || UPPER(TRIM(COALESCE(CAST(s.capacity_sqft AS VARCHAR), '')))\n  ) AS hashdiff,\n  s.warehouse_name,\n  s.city,\n  s.capacity_sqft\nFROM stg_wms_warehouses s\nWHERE NOT EXISTS (\n  SELECT 1 FROM sat_warehouse_capacity sat\n  WHERE sat.warehouse_hk = md5(UPPER(TRIM(CAST(s.warehouse_id AS VARCHAR))))\n  AND sat.hashdiff = md5(\n    UPPER(TRIM(COALESCE(CAST(s.warehouse_name AS VARCHAR), '')))\n    || '|' || UPPER(TRIM(COALESCE(CAST(s.city AS VARCHAR), ''